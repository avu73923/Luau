local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local player = Players.LocalPlayer
local cratesFolder = workspace:WaitForChild("crates")

local queue = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
if queue then
    queue([[loadstring(game:HttpGet("https://raw.githubusercontent.com/avu73923/Luau/refs/heads/main/SirenHeadLegacy"))()]])
end

local function getHRP()
    return player.Character and player.Character:FindFirstChild("HumanoidRootPart")
end

local function hopServer()
    task.wait(2)
    local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?limit=100"
    local response = request({Url = url, Method = "GET"})
    local body = HttpService:JSONDecode(response.Body)
    local servers = {}
    for _, server in pairs(body.data) do
        if server.id ~= game.JobId and server.playing < server.maxPlayers then
            table.insert(servers, server.id)
        end
    end
    if #servers > 0 then
        TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], player)
    else
        TeleportService:Teleport(game.PlaceId, player)
    end
end

task.spawn(function()
    while true do
        local crates = {}
        for _, obj in ipairs(cratesFolder:GetDescendants()) do
            if obj.Name == "crate" then
                table.insert(crates, obj)
            end
        end
        if #crates > 0 then
            for _, crate in ipairs(crates) do
                local part = (crate:IsA("BasePart") and crate) or (crate:IsA("Model") and (crate.PrimaryPart or crate:FindFirstChildWhichIsA("BasePart")))
                if part and getHRP() then
                    getHRP().CFrame = part.CFrame + Vector3.new(0, 3, 0)
                    task.wait(0.2)
                    for _, v in ipairs(crate:GetDescendants()) do
                        if v:IsA("ProximityPrompt") then
                            v.HoldDuration = 0
                            fireproximityprompt(v)
                        end
                    end
                end
            end
        else
            hopServer()
            break
        end
        task.wait(0.5)
    end
end)
